{
  "$schema": "https://www.cursor.com/schemas/environment.schema.json",
  "name": "admin-dashboard-cloud",
  "install": "npm install",
  "ports": [
    {
      "name": "Angular app",
      "port": 4200
    },
    {
      "name": "JSON API",
      "port": 3000
    }
  ],
  "start": "echo \"Cloud environment ready for UI testing\"",
  "terminals": [
    {
      "name": "api",
      "command": "npm run api"
    },
    {
      "name": "web",
      "command": "npm run start -- --host 0.0.0.0 --port 4200"
    }
  ]
}
